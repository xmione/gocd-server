<!-- config/cruise-config.xml -->
<cruise schemaVersion="139">
  <server agentAutoRegisterKey="default" serverId="__SERVER_ID__" tokenGenerationKey="__TOKEN_GENERATION_KEY__">
    <security>
      <authConfigs>
        <authConfig id="password_file" pluginId="cd.go.authentication.passwordfile">
          <property>
            <key>PasswordFilePath</key>
            <value>/godata/config/password.properties</value>
          </property>
        </authConfig>
      </authConfigs>
      <roles>
        <role name="gocd-system-administrators">
          <users>
            <user>admin</user>
          </users>
        </role>
      </roles>
      <admins>
        <user>admin</user>
      </admins>
    </security>
    <siteUrls>
      <siteUrl>http://localhost:8153</siteUrl>
    </siteUrls>
    <artifacts>
      <artifactsDir>artifacts</artifactsDir>
    </artifacts>
  </server>

  <pipelines group="badminton_court_group">
    
    <pipeline name="badminton_court-artifacts">
      <materials>
        <git url="__GIT_REPO_URL_WITH_CREDENTIALS__" branch="master" />
      </materials>
      <stage name="build">
        <jobs>
          <job name="artifact_generation">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/build-and-push.js</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="badminton_court-staging">
      <materials>
        <pipeline pipelineName="badminton_court-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="build">
        <jobs>
          <job name="build_job">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <!-- STEP 1: Decrypt Environment files -->
              <exec command="bash">
                <arg>-c</arg>
                <arg>cd /badminton_court &amp;&amp; node Scripts/docker-menu.js 13.7</arg>
              </exec>

              <!-- STEP 2: Clean up Containers and Images -->
              <exec command="bash">
                <arg>-c</arg>
                <arg>
                  echo "========================================================" &amp;&amp;
                  echo "CLEANING UP badminton_court" &amp;&amp;
                  echo "========================================================" &amp;&amp;
                  cd /badminton_court &amp;&amp;
                  docker compose --env-file .env.docker down -v --rmi all &amp;&amp;
                  docker volume rm badminton_court_poste_data badminton_court_postgres_data badminton_court_postgres_test_data badminton_court_mariadb_data 2>/dev/null || true &amp;&amp;
                  docker system prune -a --volumes -f
                </arg>
              </exec>

              <!-- STEP 3: Build and start dev profile containers -->
              <exec command="bash">
                <arg>-c</arg>
                <arg>
                  echo "========================================================" &amp;&amp;
                  echo "BUILDING badminton_court" &amp;&amp;
                  echo "========================================================" &amp;&amp;
                  cd /badminton_court &amp;&amp;
                  docker compose --env-file .env.docker --profile dev --progress=plain build --no-cache
                </arg>
              </exec>

              <exec command="bash">
                <arg>-c</arg>
                <arg>
                  echo "========================================================" &amp;&amp;
                  echo "STARTING badminton_court" &amp;&amp;
                  echo "========================================================" &amp;&amp;
                  cd /badminton_court &amp;&amp;
                  docker compose --env-file .env.docker --profile dev up -d
                </arg>
              </exec>

            </tasks>
          </job>
        </jobs>
      </stage>
      <stage name="deploy_to_gcp">
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/deploy.js staging __GITHUB_TOKEN__</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="badminton_court-production">
      <materials>
        <pipeline pipelineName="badminton_court-staging" stageName="deploy_staging" />
      </materials>

      <stage name="Build_and_Package">
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/deploy.js production __GITHUB_TOKEN__</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

  </pipelines>
<pipelines group="humrine_site_group">
  <pipeline name="humrine_site-artifacts">
    <materials>
      <git url="__HUMRINE_SITE_REPO_URL_WITH_CREDENTIALS__" branch="master" dest="humrine_site" />
    </materials>
    <stage name="build_and_push">
      <approval type="manual" />
      <jobs>
        <job name="artifact_generation">
          <resources>
            <resource>docker</resource>
            <resource>humrine_site</resource>
          </resources>
          <tasks>
            <exec command="bash">
              <arg>-c</arg>
              <arg><![CDATA[
                export GITHUB_TOKEN='__GITHUB_TOKEN__'
                cd /humrine_site
                node Scripts/build-and-push.js
              ]]></arg>
            </exec>
          </tasks>
        </job>
      </jobs>
    </stage>
  </pipeline>

  <pipeline name="humrine_site-staging">
    <materials>
      <pipeline pipelineName="humrine_site-artifacts" stageName="build_and_push" />
    </materials>
    <stage name="deploy_staging">
      <approval type="manual" />
      <jobs>
        <job name="remote_deploy">
          <resources>
            <resource>docker</resource>
            <resource>humrine_site</resource>
          </resources>
          <tasks>
            <exec command="bash">
              <arg>-c</arg>
              <arg>node /humrine_site/Scripts/deploy.js staging __GITHUB_TOKEN__</arg>
            </exec>
          </tasks>
        </job>
      </jobs>
    </stage>
  </pipeline>

  <pipeline name="humrine_site-production">
    <materials>
      <pipeline pipelineName="humrine_site-staging" stageName="deploy_staging" />
    </materials>
    <stage name="deploy_production">
      <approval type="manual" />
      <jobs>
        <job name="remote_deploy">
          <resources>
            <resource>docker</resource>
            <resource>humrine_site</resource>
          </resources>
          <tasks>
            <exec command="bash">
              <arg>-c</arg>
              <arg>node /humrine_site/Scripts/deploy.js production __GITHUB_TOKEN__</arg>
            </exec>
          </tasks>
        </job>
      </jobs>
    </stage>
  </pipeline>
</pipelines>
</cruise>