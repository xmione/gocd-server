<!-- config/cruise-config.xml -->
<cruise schemaVersion="139">
  <server agentAutoRegisterKey="default" serverId="__SERVER_ID__" tokenGenerationKey="__TOKEN_GENERATION_KEY__">
    <security>
      <authConfigs>
        <authConfig id="password_file" pluginId="cd.go.authentication.passwordfile">
          <property>
            <key>PasswordFilePath</key>
            <value>/godata/config/password.properties</value>
          </property>
        </authConfig>
      </authConfigs>
      <roles>
        <role name="gocd-system-administrators">
          <users>
            <user>admin</user>
          </users>
        </role>
      </roles>
      <admins>
        <user>admin</user>
      </admins>
    </security>
    <siteUrls>
      <siteUrl>http://localhost:8153</siteUrl>
    </siteUrls>
    <artifacts>
      <artifactsDir>artifacts</artifactsDir>
    </artifacts>
  </server>
  <pipelines group="badminton_court_group">
    <pipeline name="badminton_court-artifacts">
      <materials>
        <git url="__GIT_REPO_URL_WITH_CREDENTIALS__" branch="master" />
      </materials>
      <stage name="build_and_push">
        <approval type="manual" />
        <jobs>
          <job name="artifact_generation">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/build-and-push.js</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="badminton_court-staging">
      <materials>
        <pipeline pipelineName="badminton_court-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="deploy_staging">
        <approval type="manual" />
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/deploy.js staging __GITHUB_TOKEN__</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
    <pipeline name="badminton_court-production">
      <materials>
        <pipeline pipelineName="badminton_court-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="deploy_production">
        <approval type="manual" />
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg>node /badminton_court/Scripts/deploy.js production __GITHUB_TOKEN__</arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>
  </pipelines>
