<!-- config/cruise-config.xml -->
<cruise schemaVersion="139">
  <server agentAutoRegisterKey="default" serverId="__SERVER_ID__" tokenGenerationKey="__TOKEN_GENERATION_KEY__" siteUrl="__SITE_URL__">
    <security>
      <authConfigs>
        <authConfig id="password_file" pluginId="cd.go.authentication.passwordfile">
          <property>
            <key>PasswordFilePath</key>
            <value>/godata/config/password.properties</value>
          </property>
        </authConfig>
      </authConfigs>
      <roles>
        <role name="gocd-system-administrators">
          <users>
            <user>admin</user>
          </users>
        </role>
      </roles>
      <admins>
        <user>admin</user>
      </admins>
    </security>
    <artifacts>
      <artifactsDir>artifacts</artifactsDir>
    </artifacts>
  </server>

  <pipelines group="badminton_court_group">
    
    <pipeline name="badminton_court-artifacts">
      <materials>
        <git url="__GIT_REPO_URL_WITH_CREDENTIALS__" branch="master" />
      </materials>
      <stage name="build_and_push">
        <jobs>
          <job name="artifact_generation">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[export GITHUB_TOKEN='__GITHUB_TOKEN__' && node Scripts/generate-env.js development .env.docker && node Scripts/compile.js && echo '__GITHUB_TOKEN__' | docker login ghcr.io -u xmione --password-stdin && docker build -t ghcr.io/xmione/badminton_court-web:latest -f Dockerfile.binary . && docker push ghcr.io/xmione/badminton_court-web:latest && docker build -t ghcr.io/xmione/badminton_court-mail:latest -f Dockerfile.posteio . && docker push ghcr.io/xmione/badminton_court-mail:latest]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="badminton_court-staging">
      <materials>
        <pipeline pipelineName="badminton_court-artifacts" stageName="build_and_push" />
      </materials>
      <stage name="deploy_staging">
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[gcloud compute ssh "__GCP_VM_NAME__" --project "__GCP_PROJECT_ID__" --zone "__GCP_ZONE__" --quiet --command "export GITHUB_TOKEN='__GITHUB_TOKEN__' && sudo chown -R \$USER /app/badminton_court && git config --global --add safe.directory /app/badminton_court && cd /app/badminton_court && git pull && node Scripts/generate-env.js development .env.staging && echo '__GITHUB_TOKEN__' | sudo docker login ghcr.io -u xmione --password-stdin && sudo docker compose -f docker-compose.vm.yml --env-file .env.staging --profile staging pull && sudo docker compose -f docker-compose.vm.yml --env-file .env.staging --profile staging up -d --build"]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

    <pipeline name="badminton_court-production">
      <materials>
        <pipeline pipelineName="badminton_court-staging" stageName="deploy_staging" />
      </materials>
      <stage name="deploy_production">
        <approval type="manual" />
        <jobs>
          <job name="remote_deploy">
            <resources>
              <resource>docker</resource>
              <resource>badminton_court</resource>
            </resources>
            <tasks>
              <exec command="bash">
                <arg>-c</arg>
                <arg><![CDATA[gcloud compute ssh "__GCP_VM_NAME__" --project "__GCP_PROJECT_ID__" --zone "__GCP_ZONE__" --quiet --command "export GITHUB_TOKEN='__GITHUB_TOKEN__' && sudo chown -R \$USER /app/badminton_court && git config --global --add safe.directory /app/badminton_court && cd /app/badminton_court && git pull && node Scripts/generate-env.js docker-production .env.production && echo '__GITHUB_TOKEN__' | sudo docker login ghcr.io -u xmione --password-stdin && sudo docker compose -f docker-compose.vm.yml --env-file .env.production --profile production pull && sudo docker compose -f docker-compose.vm.yml --env-file .env.production --profile production up -d --build"]]></arg>
              </exec>
            </tasks>
          </job>
        </jobs>
      </stage>
    </pipeline>

  </pipelines>
  <agents>
    <agent hostname="gocd-agent-1" ipaddress="172.18.0.3" uuid="fe58a97f-3aa2-4951-9de7-9baba6a3cef2">
      <resources>
        <resource>docker</resource>
        <resource>badminton_court</resource>
      </resources>
    </agent>
    <agent hostname="gocd-agent-2" ipaddress="172.18.0.4" uuid="8a2fc391-f8a7-4d52-a8fe-6b225e161984">
      <resources>
        <resource>docker</resource>
        <resource>badminton_court</resource>
      </resources>
    </agent>
    <agent hostname="gocd-agent-3" ipaddress="172.18.0.5" uuid="d38d1d66-de3b-4f19-8f2d-d15242725040">
      <resources>
        <resource>docker</resource>
        <resource>badminton_court</resource>
      </resources>
    </agent>
  </agents>
</cruise>
