# Dockerfile.agent.solvpn.base
# This is the BASE image for the SolVPN build agent.
# It contains all the slow-to-build tooling:
#   - MinGW cross-compiler
#   - OpenSSL cross-compiled for Windows
#   - Python + flet
#   - zip utility
#
# This image is built ONCE by the solvpn-base-image GoCD pipeline
# and pushed to ghcr.io/xmione/solvpn-build-base:latest.
# It is NOT rebuilt on every go.ps1 option 1.6 run.
FROM gocd/gocd-agent-alpine:v25.4.0

USER root

RUN apk add --no-cache gcc musl-dev openssl-dev python3 py3-pip mingw-w64-gcc \
        make perl tar unzip zip curl && \
    pip3 install flet --break-system-packages && \
    OPENSSL_VERSION=3.3.1 && \
    curl -fsSL https://www.openssl.org/source/openssl-${OPENSSL_VERSION}.tar.gz | tar -xz -C /tmp && \
    cd /tmp/openssl-${OPENSSL_VERSION} && \
    ./Configure mingw64 \
        --cross-compile-prefix=x86_64-w64-mingw32- \
        --prefix=/usr/x86_64-w64-mingw32 \
        --openssldir=/usr/x86_64-w64-mingw32/ssl \
        no-shared no-tests && \
    make -j$(nproc) && \
    make install_sw && \
    rm -rf /tmp/openssl-${OPENSSL_VERSION}